{
  let sortedStrings = sortWith(["bbb", "a", "cc"]) { left, right =>
    if (left < right) {
      -1
    } else if (left > right) {
      1
    } else {
      0
    }
  }

  assert { sortedStrings == ["a", "bbb", "cc"] }

  let sortedDescending = sortWith([1, 3, 2]) { left, right =>
    if (left > right) {
      -1
    } else if (left < right) {
      1
    } else {
      0
    }
  }

  assert { sortedDescending == [3, 2, 1] }
}
