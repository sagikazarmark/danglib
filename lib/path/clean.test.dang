{
  # empty
  assert { clean("") == "." }

  # absolute
  assert { clean("/a/../b") == "/b" }
  assert { clean("/a//./b/") == "/a/b" }
  assert { clean("/") == "/" }

  # relative
  assert { clean("a/./b") == "a/b" }
  assert { clean("a/../../b") == "../b" }

  # whitespace
  assert { clean("a b/./c d") == "a b/c d" }
  assert { clean("/a b/../c d") == "/c d" }
  assert { clean(" ") == " " }
  assert { clean("  a b/./c d  ") == "  a b/c d  " }
  assert { clean("  /a b/../c d  ") == "  /c d  " }
}
